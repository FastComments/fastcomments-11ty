    </div>
    <pre id="code-activity" class="fc-code-panel__body">{% raw %}---
layout: base.njk
permalink: /user-activity-feed/
---

<!-- SSO userId format: `${tenantId}:${appUserId}` -->
{% fastcommentsUserActivityFeed { tenantId: "demo", userId: "demo:someone@somewhere.com" } %}{% endraw %}</pre>
  </div>
</div>
